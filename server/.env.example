PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=<your-origin-1>,<your-origin-2>
# Comma-separated origins (e.g., https://example.com,https://app.example.com). No trailing slashes.
MONGODB_URI=mongodb://localhost:27017/talentconnect
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=supersecure
ADMIN_LOGIN_MAX_ATTEMPTS=5   # Max admin login attempts per 15 minutes
REDIS_URL=redis://localhost:6379  # Optional but recommended in production for distributed rate limiting. If not set, in-memory rate limiting is used (not suitable for multi-instance deployments).

# Firebase Configuration
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_ADMIN_KEY=   # For server-side (service account JSON as string)

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5173/auth/linkedin/callback

# SMTP Email (verification + password reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false   # true for 465, false for 587/25/2525
SMTP_USER=apikey_or_username
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL="TalentConnect <no-reply@talentconnect.app>"
