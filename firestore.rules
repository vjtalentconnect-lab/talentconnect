rules_version = '2';

// All writes go through the Express backend using the Firebase Admin SDK (which bypasses these rules).
// These rules only protect against direct Firebase client SDK access from browsers or other untrusted clients.
service cloud.firestore {
  match /databases/{database}/documents {

    // users: client can read their own user document; writes are backend-only.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }

    // profiles: readable if the profile is searchable or belongs to the requester; no client writes.
    match /profiles/{profileId} {
      allow read: if (resource.data.privacySettings.profileSearchable == true) ||
                  (request.auth != null && request.auth.uid == resource.data.user);
    }

    // projects: readable only when the project is open; no client writes.
    match /projects/{projectId} {
      allow read: if resource.data.status == 'open';
    }

    // applications: no client access (reads/writes handled by Admin SDK only).
    match /applications/{applicationId} {
      allow read, write: if false;
    }

    // messages: no client access.
    match /messages/{messageId} {
      allow read, write: if false;
    }

    // notifications: no client access.
    match /notifications/{notificationId} {
      allow read, write: if false;
    }

    // auth flows: no client access.
    match /emailVerifications/{verificationId} {
      allow read, write: if false;
    }
    match /passwordResets/{resetId} {
      allow read, write: if false;
    }

    // Default deny for everything else and for all writes from clients.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
